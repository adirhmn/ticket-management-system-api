{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AuthorizeAndRevokeSSHAccess",
      "Effect": "Allow",
      "Action": [
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupIngress"
      ],
      "Resource": "arn:aws:ec2:ap-southeast-3:*:security-group/*"
    }
  ]
}
